+"""Small PyTorch fallback for the PointNet++ ops used by AdaPoinTr inference.
+
+The original project expects the external ``pointnet2_ops`` CUDA extension.
+For this experiment we only need farthest-point sampling and feature gather.
+These implementations run on the input tensor device and preserve the same
+shapes as the extension API.
+"""
+
+from __future__ import annotations
+
+import torch
+
+
+def furthest_point_sample(xyz: torch.Tensor, npoint: int) -> torch.Tensor:
+    if xyz.ndim != 3 or xyz.shape[-1] != 3:
+        raise ValueError(f"xyz must be [B, N, 3], got {tuple(xyz.shape)}")
+    bsz, n_points, _ = xyz.shape
+    npoint = min(int(npoint), n_points)
+    centroids = torch.zeros(bsz, npoint, dtype=torch.long, device=xyz.device)
+    distance = torch.full((bsz, n_points), float("inf"), device=xyz.device, dtype=xyz.dtype)
+    farthest = torch.zeros(bsz, dtype=torch.long, device=xyz.device)
+    batch_indices = torch.arange(bsz, dtype=torch.long, device=xyz.device)
+
+    for i in range(npoint):
+        centroids[:, i] = farthest
+        centroid = xyz[batch_indices, farthest].view(bsz, 1, 3)
+        dist = ((xyz - centroid) ** 2).sum(dim=-1)
+        distance = torch.minimum(distance, dist)
+        farthest = distance.max(dim=1).indices
+    return centroids
+
+
+def gather_operation(features: torch.Tensor, idx: torch.Tensor) -> torch.Tensor:
+    if features.ndim != 3:
+        raise ValueError(f"features must be [B, C, N], got {tuple(features.shape)}")
+    if idx.ndim != 2:
+        raise ValueError(f"idx must be [B, S], got {tuple(idx.shape)}")
+    idx = idx.to(device=features.device, dtype=torch.long)
+    expanded = idx.unsqueeze(1).expand(-1, features.shape[1], -1)
+    return features.gather(dim=2, index=expanded)
